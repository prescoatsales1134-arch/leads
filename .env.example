# Copy to .env and fill in your values.
# Keep .env.example as a template only; put real values in .env (which is gitignored).

SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-side only (never expose to browser). Used in server.js for Supabase access that bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# n8n webhook URLs – leave empty until you create the workflows; the app will still run (login, dashboard, Settings). Add URLs later and run: npm run config
N8N_GENERATE_LEADS_WEBHOOK=
# Google Maps / reviews lead generation (separate n8n workflow from LinkedIn)
N8N_GENERATE_GOOGLE_LEADS_WEBHOOK=
# One URL only, e.g. https://your-n8n.com/webhook/chatbot (no space, no extra text)
N8N_CHATBOT_WEBHOOK=
# Message assistant (below Generate Leads): POST { message, leads } for outreach advice. n8n calls OpenAI with leads context.
N8N_MESSAGE_ASSISTANT_WEBHOOK=
# HubSpot sync: POST { leads: [...] } to this webhook. CSV export is in-app download only (no webhook).
N8N_SYNC_HUBSPOT_WEBHOOK=

# Optional fallback
OPENAI_API_KEY=
